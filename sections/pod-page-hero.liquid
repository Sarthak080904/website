{{ 'section-pod-page-hero.css' | asset_url | stylesheet_tag }}

<section class="pod-page-hero">
  <div class="pod-page-hero__inner page-width">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="pod-page-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="pod-page-hero__heading">{{ section.settings.heading | escape }}</h1>
    </div>
    {%- if section.settings.text != blank -%}
      <div class="pod-page-hero__text rte">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "POD page hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Store guide"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Helpful information for confident ordering."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Clear product details, simple policies, and friendly support make custom shopping easier.</p>"
    }
  ],
  "presets": [
    {
      "name": "POD page hero"
    }
  ]
}
{% endschema %}
