{{ 'section-pod-product-universe.css' | asset_url | stylesheet_tag }}

<section class="pod-product-universe">
  <div class="pod-product-universe__inner page-width">
    <div class="pod-product-universe__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="pod-product-universe__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="pod-product-universe__heading">{{ section.settings.heading | escape }}</h2>
      </div>
      {%- if section.settings.text != blank -%}
        <div class="pod-product-universe__text rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="pod-product-universe__grid">
      {%- for block in section.blocks -%}
        {%- assign card_tag = 'div' -%}
        {%- if block.settings.link != blank -%}
          {%- assign card_tag = 'a' -%}
        {%- endif -%}
        <{{ card_tag }}
          class="pod-product-universe__item"
          {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
          style="--pod-card-color: {{ block.settings.color }};"
          {{ block.shopify_attributes }}
        >
          <span class="pod-product-universe__number">{{ forloop.index }}</span>
          <h3 class="pod-product-universe__title">{{ block.settings.title | escape }}</h3>
          <p class="pod-product-universe__description">{{ block.settings.description | escape }}</p>
          {%- if block.settings.link_label != blank -%}
            <span class="pod-product-universe__link">{{ block.settings.link_label | escape }}</span>
          {%- endif -%}
        </{{ card_tag }}>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "POD product universe",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Product universe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "One design can become a full product line."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Start with high-demand products, test what sells, then expand into more categories without buying stock upfront.</p>"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Apparel"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "T-shirts, hoodies, oversized fits, polos, and kids wear."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Card color",
          "default": "#1D2634"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "POD product universe",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Apparel",
            "description": "T-shirts, oversized tees, polos, hoodies, sweatshirts, and kids wear.",
            "color": "#1D2634"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Accessories",
            "description": "Caps, tote bags, phone cases, laptop sleeves, and everyday carry.",
            "color": "#005EFF"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Home and gifts",
            "description": "Mugs, posters, cushions, decor, pet products, and gifting bundles.",
            "color": "#F2553D"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Business prints",
            "description": "Business cards, flyers, stickers, banners, labels, and marketing kits.",
            "color": "#157A4E"
          }
        }
      ]
    }
  ]
}
{% endschema %}
