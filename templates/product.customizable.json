{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "custom_upload": {
          "type": "custom_upload",
          "settings": {
            "label": "Upload your design",
            "help_text": "For best print quality, use a high-resolution PNG or PDF with a transparent background (max 20MB).",
            "required": true,
            "show_notes": true
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description"
        },
        "print_details": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Print & proofing process",
            "icon": "clipboard",
            "content": "<p>After you order, we'll review your uploaded design for print quality. If there's an issue with resolution or placement, we'll contact you before printing. Add your specific turnaround time here.</p>"
          }
        },
        "fit_details": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Fabric & fit",
            "icon": "shirt",
            "content": "<p>Add fabric composition, fit notes, and wash care here per product.</p>"
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "variant_picker",
        "custom_upload",
        "quantity_selector",
        "buy_buttons",
        "description",
        "print_details",
        "fit_details",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "disclosures": {
      "type": "disclosures",
      "settings": {
        "padding_top": 36,
        "padding_bottom": 0
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "disclosures",
    "related-products"
  ]
}
