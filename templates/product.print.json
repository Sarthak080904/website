{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "dropdown",
            "swatch_shape": "circle"
          }
        },
        "custom_upload": {
          "type": "custom_upload",
          "settings": {
            "label": "Upload your artwork",
            "help_text": "Print-ready PDF preferred. JPG/PNG also accepted (max 20MB).",
            "required": true,
            "show_notes": true
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": false
          }
        },
        "description": {
          "type": "description"
        },
        "specs": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Size & paper specs",
            "icon": "ruler",
            "content": "<p>Add size options, paper stock/GSM, and finish (matte/gloss/spot UV) details here per product.</p>"
          }
        },
        "turnaround": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Turnaround & shipping",
            "icon": "plane",
            "content": "<p>Add production turnaround time and shipping details here.</p>"
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "variant_picker",
        "custom_upload",
        "quantity_selector",
        "buy_buttons",
        "description",
        "specs",
        "turnaround",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "hide",
        "hide_variants": false,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "disclosures": {
      "type": "disclosures",
      "settings": {
        "padding_top": 36,
        "padding_bottom": 0
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    }
  },
  "order": [
    "main",
    "disclosures",
    "related-products"
  ]
}
